#!/usr/bin/env bash
# floodsd ("flood standalone") — standalone remote load-generator.
#
# A deliberately different name from `floodfd` (the zsh function in
# zsh/firedancer-flood.zsh) so the two can coexist on the same machine
# without colliding: same behavior and on-disk state format, ported to
# plain bash — no zsh, no dotfiles, nothing sourced into any shell config.
# Works from bash or zsh (or any shell) since it's a normal executable, not
# a sourced function, and works on any distro with bash, `ip`, and (for
# `floodsd dpdk`) apt/dnf/yum.
#
# Load-tests a remote firedancer validator from a *separate* box: always
# sends 64B (min-sized) UDP packets to dport 9000, sourced from port 8424 —
# this box's egress firewall only allows outbound traffic sourced from that
# port (see FLOOD_SPORT below). Two engines, chosen explicitly each run:
#   floodsd dpdk    DPDK pktgen (userspace, needs a NIC bound to vfio-pci/mlx5)
#   floodsd kernel  in-kernel pktgen module (no DPDK/hugepages needed)
#
# Bonded NICs: `floodsd setup` can target a bond master directly — it's just
# IP-level probing/ARP. Both flood engines can't, though: `floodsd dpdk`
# needs a real PCI device, and `floodsd kernel` needs a real per-queue
# hardware TX ring — a bond is a purely software netdevice with neither, and
# pktgen driving one directly tends to surface as skb/protocol errors rather
# than a clean failure. Pick one of the bond's slaves instead for either
# engine (see _fd_pick_iface's bond labeling); if that slave is still
# enslaved, `floodsd dpdk` offers to pull it out of the bond first and
# `floodsd restore` puts it back (see _fd_bond_detach/_fd_bond_reattach).
#
# `floodsd setup` resolves and saves the target once: pick the sending NIC,
# enter the destination IP, then floodsd sends it a UDP probe (source port
# pinned to $FLOOD_SPORT — ICMP ping has no source port to pin, so it's
# dropped outbound by this box's egress firewall even though inbound ICMP
# works) and reads the resolved MAC out of the neighbor table, which doubles
# as a reachability check before you start flooding. Enter keeps the last
# value at every subsequent prompt. Works whether the target is on-link or a
# routed hop away (see _fd_nexthop_ip) — when routed, the router's MAC gets
# resolved and used at L2 while the target's real IP still goes in the IP
# header, exactly like normal routing.
#
# `floodsd setup-srcport` overrides the default source port (8424) if this
# box's egress firewall pins a different one — run it before `floodsd setup`
# on a box where the default doesn't get probes out.
#
# `floodsd diagnose` is a read-only, opt-in health check (link state, route/
# next-hop, rp_filter, python3, a best-effort firewall-rule grep) — nothing
# else in floodsd calls it, so it's only there when you go looking for it.
# When `floodsd setup` itself fails to resolve a MAC, it also auto-runs a
# short tcpdump-based check (see _fd_diagnose_probe) to tell a local firewall
# drop apart from an upstream block — but only on that failure path, so a
# normal box on a normal network never sees any of this.
#
# `floodsd kernel` drops you into an interactive prompt (start / start
# <mpps|max> / stop / quit) rather than a one-shot run — see its own header
# comment below for the command set.

set -uo pipefail

FLOOD_DPORT=9000  # target port on the validator under test
FLOOD_SPORT=8424  # default source port everything egresses from — override per-box with `floodsd setup-srcport` if this box's egress firewall pins a different port

FLOODSD_STATE_DIR="$HOME/.config/floodsd"
FLOODSD_STATE_FILE="$FLOODSD_STATE_DIR/state"
FLOODSD_VFIO_STATE="$FLOODSD_STATE_DIR/vfio-state"
FLOODSD_BOND_STATE="$FLOODSD_STATE_DIR/bond-state"
FLOODSD_DPDK_CMDS="$FLOODSD_STATE_DIR/dpdk.pkt"
_floodsd_get() { grep "^$1=" "$FLOODSD_STATE_FILE" 2>/dev/null | cut -d= -f2-; }
_floodsd_set() {
    local key=$1 val=$2
    mkdir -p "$(dirname "$FLOODSD_STATE_FILE")"
    local tmp="${FLOODSD_STATE_FILE}.tmp"
    { [ -f "$FLOODSD_STATE_FILE" ] && grep -v "^$key=" "$FLOODSD_STATE_FILE"; printf '%s=%s\n' "$key" "$val"; } > "$tmp"
    mv "$tmp" "$FLOODSD_STATE_FILE"
}

# The egress-allowed source port varies by box (whatever its firewall pins),
# so a saved override (see `floodsd setup-srcport`) always beats the
# FLOOD_SPORT default above.
_fd_saved_sport=$(_floodsd_get sport)
[ -n "$_fd_saved_sport" ] && FLOOD_SPORT=$_fd_saved_sport

# ── Shared DPDK/NIC helpers ───────────────────────────

# _fd_bond_tag <iface>: prints a bracketed annotation for _fd_pick_iface —
# "[bond, mode <N>, slaves: a,b]" if <iface> is a bonding master, "[bonded
# slave of <bond>]" if it's enslaved, or "" otherwise.
_fd_bond_tag() {
    local iface=$1 mode slaves master
    if [ -d "/sys/class/net/$iface/bonding" ]; then
        mode=$(awk '{print $1}' "/sys/class/net/$iface/bonding/mode" 2>/dev/null)
        slaves=$(cat "/sys/class/net/$iface/bonding/slaves" 2>/dev/null | tr ' ' ',')
        echo "[bond${mode:+, mode $mode}${slaves:+, slaves: $slaves}]"
        return
    fi
    master=$(readlink -f "/sys/class/net/$iface/master" 2>/dev/null)
    [ -n "$master" ] && echo "[bonded slave of ${master##*/}]"
}

# _fd_pick_iface <prefix> <label> [current]: list network interfaces and
# prompt for one, printing the choice to stdout. Enter keeps [current] if given.
# Bonding masters and their slaves are both listed (see _fd_bond_tag) — only
# `floodsd setup` wants the bond master (plain IP-level probing/ARP); both
# `floodsd kernel` and `floodsd dpdk` need a real physical NIC, so pick a
# slave for either of those (see the bond handling in _floodsd_kernel and
# _floodsd_dpdk).
_fd_pick_iface() {
    local prefix=$1 label=$2 cur=$3
    local ifaces=() i idx=1 drv bondtag state statetag
    echo "Available interfaces:" >&2
    for i in /sys/class/net/*; do
        [ -e "$i" ] || continue
        i=${i##*/}
        [ "$i" = lo ] && continue
        drv=$(basename "$(readlink -f "/sys/class/net/$i/device/driver" 2>/dev/null)" 2>/dev/null)
        bondtag=$(_fd_bond_tag "$i")
        # Only flag non-"up" state — healthy interfaces stay quiet, so this
        # doesn't clutter the picker for the common case.
        state=$(cat "/sys/class/net/$i/operstate" 2>/dev/null)
        statetag=""; [ -n "$state" ] && [ "$state" != up ] && statetag="($state) "
        ifaces+=("$i")
        printf "  %d) %-20s %s\n" "$idx" "$i" "${statetag}${drv:+driver: $drv }${bondtag}" >&2
        idx=$((idx + 1))
    done
    if [ "${#ifaces[@]}" -eq 0 ]; then
        echo "$prefix: no network interfaces found." >&2
        return 1
    fi

    local sel
    read -rp "${label}${cur:+ (Enter = keep '$cur')} [1-${#ifaces[@]}]: " sel
    if [ -z "$sel" ]; then
        [ -z "$cur" ] && { echo "$prefix: no interface selected." >&2; return 1; }
        echo "$cur"
        return 0
    fi
    if ! [[ "$sel" =~ ^[0-9]+$ ]] || [ "$sel" -lt 1 ] || [ "$sel" -gt "${#ifaces[@]}" ]; then
        echo "$prefix: invalid selection '$sel'." >&2
        return 1
    fi
    echo "${ifaces[$((sel - 1))]}"
}

# _fd_is_mellanox <iface> <curdrv>: detects (and lets the user confirm/
# override) whether <iface> is a bifurcated Mellanox PMD — DPDK drives it
# while it stays on the kernel driver, so it never needs a vfio-pci rebind.
_fd_is_mellanox() {
    local iface=$1 curdrv=$2 mellanox=0
    case "$curdrv" in mlx5_core|mlx5) mellanox=1 ;; esac
    local defans; [ "$mellanox" = 1 ] && defans=Y || defans=N
    [ -n "$curdrv" ] && echo "Detected kernel driver for $iface: $curdrv"
    local ans
    read -rp "Mellanox/mlx5 NIC (no vfio-pci rebind needed)? [$defans]: " ans
    ans=${ans:-$defans}
    case "$ans" in y|Y|yes|Yes) return 0 ;; *) return 1 ;; esac
}

# _fd_lcore_plan <prefix> <ntx>: lays out DPDK lcores top-down (fits a
# 16-core box): main 15 | RX 14 | TX 13, 12, ... Every core past the main
# and RX cores is a dedicated TX (generation) core, and TX throughput scales
# with their count. DPDK would otherwise default the main lcore to the
# lowest core in -l (a TX core here), so it's pinned explicitly with
# --main-lcore. On success prints "<main> <rxcore> <txlo> <txrange> <lcores>
# <map> <est>" to stdout; on failure (machine too small, or <ntx> would run
# past core 0) prints an error prefixed with <prefix> and returns 1.
_fd_lcore_plan() {
    local prefix=$1 ntx=$2
    local main=15 rxcore=14 txhi=13
    local txlo=$((txhi - ntx + 1))
    if [ ! -d "/sys/devices/system/cpu/cpu$main" ]; then
        echo "$prefix: layout needs at least 16 cores (uses up to core $main); machine has $(nproc)." >&2
        return 1
    fi
    if [ "$txlo" -lt 0 ]; then
        echo "$prefix: $ntx TX cores would run past core 0 (lowest = $txlo). Choose fewer." >&2
        return 1
    fi
    local lcores="${txlo}-${main}"
    local txrange="$txhi"
    [ "$txlo" -lt "$txhi" ] && txrange="${txlo}-${txhi}"
    local map="[${rxcore}:${txrange}].0"
    local est=$((ntx * 30))
    echo "$main $rxcore $txlo $txrange $lcores $map $est"
}

# _fd_check_numa <prefix> <iface> <nicnode> <lo> <hi>: warns if any core in
# [lo, hi] isn't on the NIC's NUMA node — cross-socket DMA skews throughput.
_fd_check_numa() {
    local prefix=$1 iface=$2 nicnode=$3 lo=$4 hi=$5
    if [ -z "$nicnode" ] || [ "$nicnode" = "-1" ]; then return 0; fi
    local c cnode badcores="" n
    for ((c = lo; c <= hi; c++)); do
        cnode=""
        for n in /sys/devices/system/cpu/cpu$c/node*; do
            [ -e "$n" ] || continue
            cnode=${n##*/node}
        done
        [ -n "$cnode" ] && [ "$cnode" != "$nicnode" ] && badcores="${badcores} $c"
    done
    if [ -n "$badcores" ]; then
        echo "$prefix: WARNING — $iface is on NUMA node $nicnode but core(s)$badcores are on another node."
        echo "  Cross-socket DMA will skew results; pin to cores on node $nicnode for accurate numbers."
    fi
}

# _fd_reserve_hugepages <ntx>: reserves 1024 x 2MB hugepages per TX core and
# mounts a 2MB hugetlbfs at /mnt/huge if one isn't already mounted.
_fd_reserve_hugepages() {
    local ntx=$1
    local npages=$(( 1024 * ntx ))
    echo "Reserving $npages x 2MB hugepages ($((npages * 2)) MiB)..."
    echo "$npages" | sudo tee /sys/kernel/mm/hugepages/hugepages-2048kB/nr_hugepages >/dev/null
    if ! grep -q 'hugetlbfs.*pagesize=2M' /proc/mounts; then
        sudo mkdir -p /mnt/huge && sudo mount -t hugetlbfs -o pagesize=2M nodev /mnt/huge
    fi
}

# _fd_vfio_bind <tool> <iface> <pci> <curdrv> <statefile> [peer] [ip]: binds
# <iface> to vfio-pci for DPDK and records pci/drv/if/ip/peer in <statefile>
# so _fd_vfio_restore can undo it later. Only call this for non-Mellanox
# NICs (see _fd_is_mellanox) — Mellanox never needs rebinding.
_fd_vfio_bind() {
    local tool=$1 iface=$2 pci=$3 curdrv=$4 state=$5 peer=$6 ip=$7
    echo "Binding $iface ($pci, ${curdrv:-unknown}) to vfio-pci for DPDK..."
    sudo modprobe vfio-pci 2>/dev/null
    if ! ls /sys/kernel/iommu_groups/* >/dev/null 2>&1; then
        echo "  NOTE: no IOMMU groups found. vfio-pci needs an IOMMU (boot with 'intel_iommu=on iommu=pt'),"
        echo "        or enable no-IOMMU mode: echo 1 | sudo tee /sys/module/vfio/parameters/enable_unsafe_noiommu_mode"
    fi
    if command -v dpdk-devbind.py >/dev/null 2>&1; then
        sudo dpdk-devbind.py --bind=vfio-pci "$pci"
    else
        echo vfio-pci | sudo tee "/sys/bus/pci/devices/$pci/driver_override" >/dev/null
        [ -e "/sys/bus/pci/devices/$pci/driver" ] && \
            echo "$pci" | sudo tee "/sys/bus/pci/devices/$pci/driver/unbind" >/dev/null
        echo "$pci" | sudo tee /sys/bus/pci/drivers_probe >/dev/null
    fi
    mkdir -p "$(dirname "$state")"
    printf 'pci=%s\ndrv=%s\nif=%s\nip=%s\npeer=%s\n' "$pci" "$curdrv" "$iface" "$ip" "$peer" > "$state"
    echo "  To rebind the kernel driver + restore $iface later:  $tool restore"
}

# _fd_vfio_restore <prefix> <statefile>: undoes _fd_vfio_bind — rebinds the
# interface to its kernel driver, renames the reborn netdev back, restores
# its IP, and bounces a peer interface if one was recorded.
_fd_vfio_restore() {
    local prefix=$1 state=$2
    if [ ! -f "$state" ]; then
        echo "$prefix: no saved state ($state) — nothing was bound to vfio-pci."
        return 1
    fi

    local pci drv iface ip peer k v
    while IFS='=' read -r k v; do
        case "$k" in
            pci) pci=$v ;; drv) drv=$v ;;
            if)  iface=$v ;; ip) ip=$v ;; peer) peer=$v ;;
        esac
    done < "$state"
    if [ -z "$pci" ]; then
        echo "$prefix: state file is malformed; remove $state and re-run setup."
        return 1
    fi

    echo "Rebinding $pci to kernel driver '${drv:-?}'..."
    if command -v dpdk-devbind.py >/dev/null 2>&1 && [ -n "$drv" ]; then
        sudo dpdk-devbind.py --bind="$drv" "$pci"
    else
        echo "$pci" | sudo tee /sys/bus/pci/drivers/vfio-pci/unbind >/dev/null 2>&1
        echo "" | sudo tee "/sys/bus/pci/devices/$pci/driver_override" >/dev/null
        if [ -n "$drv" ] && [ -d "/sys/bus/pci/drivers/$drv" ]; then
            echo "$pci" | sudo tee "/sys/bus/pci/drivers/$drv/bind" >/dev/null 2>&1
        fi
        echo "$pci" | sudo tee /sys/bus/pci/drivers_probe >/dev/null 2>&1
    fi

    # The kernel re-creates the netdev under a fresh name; rename it back.
    local newname="" n
    for n in /sys/bus/pci/devices/$pci/net/*; do
        [ -e "$n" ] || continue
        newname=${n##*/}
    done
    if [ -z "$newname" ]; then
        echo "$prefix: device rebound but no netdev appeared for $pci."
        echo "  Check 'ip link'; you may need to re-run, or driver '$drv' failed to attach."
        return 1
    fi
    iface=${iface:-$newname}
    if [ "$newname" != "$iface" ]; then
        echo "Renaming '$newname' -> '$iface'..."
        sudo ip link set "$newname" down && \
        sudo ip link set "$newname" name "$iface"
    fi
    sudo ip link set "$iface" up

    if [ -n "$ip" ] && ! ip -4 -o addr show dev "$iface" | grep -q "${ip%%/*}"; then
        echo "Re-adding $ip to $iface (lost when the netdev was destroyed)..."
        sudo ip addr add "$ip" dev "$iface"
    fi
    if [ -n "$peer" ] && ip link show "$peer" >/dev/null 2>&1; then
        echo "Bouncing $peer to re-establish carrier on the loopback link..."
        sudo ip link set "$peer" down && sudo ip link set "$peer" up
    fi

    rm -f "$state"
    echo "Done — $iface is back on the kernel driver."
    [ -n "$peer" ] && echo "  $peer link restored."
}

# _fd_bond_detach <iface>: if <iface> is currently an active bonding slave,
# offers to remove it from its bond before DPDK takes it over — DPDK's
# pktgen talks to the NIC directly (or, for vfio-pci NICs, needs the kernel
# driver detached entirely), and leaving it enslaved means the bonding
# driver is still trying to use the same NIC for kernel traffic underneath
# DPDK, corrupting both. Records <iface>/<bond> in $FLOODSD_BOND_STATE
# (independent of $FLOODSD_VFIO_STATE, since Mellanox NICs skip vfio
# binding entirely but still need to be re-enslaved on restore) so
# `floodsd restore` can re-add it afterward.
_fd_bond_detach() {
    local iface=$1 master
    master=$(readlink -f "/sys/class/net/$iface/master" 2>/dev/null)
    [ -z "$master" ] && return 0
    master=${master##*/}

    echo "'$iface' is currently enslaved to bond '$master'."
    local ans
    read -rp "Remove it from the bond before using it for DPDK? [Y/n]: " ans
    case "${ans:-Y}" in
        n|N|no|No)
            echo "floodsd dpdk: leaving '$iface' enslaved to '$master' — expect vfio-pci bind failures or a destabilized bond."
            return 0
            ;;
    esac

    echo "Removing $iface from bond $master..."
    echo "-$iface" | sudo tee "/sys/class/net/$master/bonding/slaves" >/dev/null
    # Verify the release actually took rather than assuming the sysfs write
    # worked — same reasoning as _fd_kernel_cleanup_all's post-write check.
    if [ -n "$(readlink -f "/sys/class/net/$iface/master" 2>/dev/null)" ]; then
        echo "  WARNING: '$iface' still shows as enslaved to '$master' after asking the bond to release it — DPDK may still conflict with it."
    fi
    mkdir -p "$(dirname "$FLOODSD_BOND_STATE")"
    printf 'if=%s\nbond=%s\n' "$iface" "$master" > "$FLOODSD_BOND_STATE"
    echo "  Recorded — 'floodsd restore' will re-add it to '$master' afterward."
}

# _fd_bond_reattach: undoes _fd_bond_detach — re-adds the recorded interface
# to its bond. Run after _fd_vfio_restore (if that ran at all — Mellanox
# NICs never get vfio-bound, so this is often the only restore step needed).
_fd_bond_reattach() {
    [ -f "$FLOODSD_BOND_STATE" ] || return 1
    local iface bond k v
    while IFS='=' read -r k v; do
        case "$k" in if) iface=$v ;; bond) bond=$v ;; esac
    done < "$FLOODSD_BOND_STATE"
    if [ -z "$iface" ] || [ -z "$bond" ]; then
        echo "floodsd restore: bond-state file is malformed; remove $FLOODSD_BOND_STATE and re-enslave manually."
        rm -f "$FLOODSD_BOND_STATE"
        return 1
    fi
    if ! ip link show "$bond" >/dev/null 2>&1; then
        echo "floodsd restore: bond '$bond' no longer exists — skipping re-enslave of '$iface'."
        rm -f "$FLOODSD_BOND_STATE"
        return 1
    fi

    echo "Re-adding $iface to bond $bond..."
    sudo ip link set "$iface" down
    echo "+$iface" | sudo tee "/sys/class/net/$bond/bonding/slaves" >/dev/null

    # Verify the sysfs write actually took rather than assuming it worked —
    # same reasoning as _fd_kernel_cleanup_all's post-write check.
    local nowmaster
    nowmaster=$(readlink -f "/sys/class/net/$iface/master" 2>/dev/null)
    rm -f "$FLOODSD_BOND_STATE"
    if [ -z "$nowmaster" ]; then
        echo "floodsd restore: WARNING — '$iface' doesn't show as enslaved to any bond after re-adding it to '$bond'."
        echo "  Check manually: ip link show $iface ; cat /sys/class/net/$bond/bonding/slaves"
        return 1
    fi
    if [ "${nowmaster##*/}" != "$bond" ]; then
        echo "floodsd restore: WARNING — '$iface' ended up enslaved to '${nowmaster##*/}', not '$bond' — check manually."
        return 1
    fi
    echo "Done — $iface is back in bond $bond."
}

# ── floodsd ───────────────────────────────────────────

# _fd_udp_probe <iface> <destip> <destport> <srcport>: sends one UDP
# datagram bound to <srcport> and <iface> (SO_BINDTODEVICE, needs root) to
# <destip>:<destport>. Used in place of ICMP ping for the setup reachability
# check: this box's egress firewall keys off source port, which ICMP has no
# concept of, so ping is dropped outbound even though inbound ICMP works. A
# UDP datagram sourced from the flood's own port ($FLOOD_SPORT) gets through
# and is enough to trigger ARP resolution — no reply on <destport> is
# required or expected.
_fd_udp_probe() {
    local iface=$1 destip=$2 destport=$3 srcport=$4
    if ! command -v python3 >/dev/null 2>&1; then
        echo "floodsd: python3 not found (needed to send a UDP probe from a pinned source port) — install python3 and re-run." >&2
        return 1
    fi
    sudo python3 - "$iface" "$destip" "$destport" "$srcport" <<'PYEOF'
import socket, sys
iface, destip, destport, srcport = sys.argv[1], sys.argv[2], int(sys.argv[3]), int(sys.argv[4])
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
try:
    s.setsockopt(socket.SOL_SOCKET, 25, iface.encode())  # SO_BINDTODEVICE
except OSError:
    pass
try:
    s.bind(('0.0.0.0', srcport))
    s.sendto(b'floodsd-probe', (destip, destport))
except OSError as e:
    sys.exit(f"floodsd: UDP probe failed: {e}")
finally:
    s.close()
PYEOF
}

# _fd_nexthop_ip <iface> <destip>: prints the IP whose MAC actually needs
# resolving to reach <destip> out <iface> — <destip> itself if it's on-link
# (same subnet, no router), or the next-hop router's IP if <destip> is a
# routed hop away. This matters because the kernel only ever ARPs for
# whichever of those two is the real L2 neighbor: if there's a router in
# between, `ip neigh show <destip>` can never populate no matter how many
# probes you send — only the router's IP ever gets a neighbor entry. Packets
# still carry <destip> as their IP destination; only the resolved MAC (the
# L2 next hop) differs, exactly as normal routing works.
_fd_nexthop_ip() {
    local iface=$1 destip=$2
    ip route get "$destip" oif "$iface" 2>/dev/null | awk '{
        for (i = 1; i <= NF; i++) if ($i == "via") { print $(i + 1); exit }
        print $1; exit
    }'
}

# _fd_diagnose_probe <iface> <destip> <destport> <srcport> <nexthop>: only
# called after a setup probe has already failed to resolve a MAC — never on
# the happy path, so a normal box never sees this. Re-sends one probe under
# a short tcpdump capture (if tcpdump is installed) to tell apart "packet
# never left the NIC" (this box's own iptables/nftables OUTPUT chain is
# dropping it — fixable here, e.g. with `floodsd setup-srcport`) from
# "packet left fine, nothing came back" (blocked further upstream — a router
# ACL, a cloud security group/NACL, or $nexthop being unreachable — not
# fixable from this box). Falls back to a manual suggestion if tcpdump isn't
# available.
_fd_diagnose_probe() {
    local iface=$1 destip=$2 destport=$3 srcport=$4 nexthop=$5
    echo
    echo "Diagnosing why $nexthop didn't resolve..."

    local state
    state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null)
    [ -n "$state" ] && [ "$state" != up ] && \
        echo "  '$iface' operstate is '$state', not 'up' — check the cable/link before anything else."

    if ! command -v tcpdump >/dev/null 2>&1; then
        echo "  tcpdump not found — can't auto-check whether probes leave $iface."
        echo "  Manually: 'sudo tcpdump -ni $iface udp or arp' in one shell, re-run 'floodsd setup' in another."
        return
    fi

    local cap
    if ! cap=$(mktemp /tmp/floodsd-diag-XXXXXX.pcap); then
        echo "  couldn't create a temp file for the capture (is /tmp writable?) — skipping the auto tcpdump check."
        echo "  Manually: 'sudo tcpdump -ni $iface udp or arp' in one shell, re-run 'floodsd setup' in another."
        return
    fi
    sudo timeout 3 tcpdump -ni "$iface" -w "$cap" "udp port $srcport or arp" >/dev/null 2>&1 &
    local tcpdump_pid=$!
    sleep 0.3
    _fd_udp_probe "$iface" "$destip" "$destport" "$srcport" >/dev/null 2>&1
    wait "$tcpdump_pid" 2>/dev/null

    local seen=0
    sudo test -s "$cap" && seen=$(sudo tcpdump -nr "$cap" 2>/dev/null | wc -l | tr -d ' ')
    sudo rm -f "$cap"

    if [ "${seen:-0}" -gt 0 ]; then
        echo "  Probe DID leave $iface ($seen packet(s) captured) — the block is further upstream:"
        echo "    a router ACL, cloud security group/NACL, or $nexthop itself being unreachable/down."
        echo "    This box's own firewall looks fine; check with whoever owns the network path to $destip."
    else
        echo "  Probe did NOT leave $iface — this box's own firewall is dropping it before it hits the wire."
        echo "    Check: sudo iptables -S OUTPUT   /   sudo nft list ruleset"
        echo "    Look for a rule keyed on src port $srcport, dst port $destport, or destination $destip."
        echo "    If the allowed source port differs, fix it with: floodsd setup-srcport"
    fi
}

# floodsd setup: pick the sending NIC, take a destination IP, resolve the
# real L2 next hop (see _fd_nexthop_ip — the target itself if on-link, or a
# router if routed), then send a UDP probe (see _fd_udp_probe) and read the
# resolved MAC out of the neighbor table. The probe doubles as a
# reachability check — if no ARP entry ever resolves, something's wrong with
# routing/cabling before you ever get to flooding.
_floodsd_setup() {
    local iface
    iface=$(_fd_pick_iface "floodsd" "Sending NIC" "$(_floodsd_get if)") || return 1

    if ! ip link show "$iface" >/dev/null 2>&1; then
        echo "floodsd setup: interface '$iface' not found."
        return 1
    fi

    if ! ip -4 -o addr show dev "$iface" | grep -q .; then
        local cidr
        read -rp "$iface has no IPv4 (needed to ping/ARP the target). Assign one (e.g. 10.0.0.2/24): " cidr
        [ -z "$cidr" ] && { echo "floodsd setup: no address given, aborting."; return 1; }
        sudo ip addr add "$cidr" dev "$iface" || return 1
    fi

    local curdestip destip
    curdestip=$(_floodsd_get destip)
    read -rp "Destination IP (the validator under test)${curdestip:+ (Enter = keep '$curdestip')}: " destip
    destip=${destip:-$curdestip}
    [ -z "$destip" ] && { echo "floodsd setup: no destination IP given."; return 1; }

    local nexthop
    nexthop=$(_fd_nexthop_ip "$iface" "$destip")
    if [ -z "$nexthop" ]; then
        echo "floodsd setup: no route to $destip out $iface — check routing/cabling before flooding."
        return 1
    fi
    if [ "$nexthop" != "$destip" ]; then
        echo "$destip is routed via $nexthop (not on-link) — resolving $nexthop's MAC; packets stay addressed (IP) to $destip."
    fi

    # A prior failed attempt can leave a FAILED/INCOMPLETE neighbor entry
    # behind, which makes the kernel back off re-ARPing it for a while —
    # silently turning "retry" into a no-op. Flushing first keeps retries real.
    sudo ip neigh flush to "$nexthop" dev "$iface" >/dev/null 2>&1

    echo "Probing $destip:$FLOOD_DPORT via $iface (UDP, src port $FLOOD_SPORT) to resolve $nexthop's MAC..."
    if ! _fd_udp_probe "$iface" "$destip" "$FLOOD_DPORT" "$FLOOD_SPORT"; then
        echo "floodsd setup: couldn't send a UDP probe to $destip:$FLOOD_DPORT from $iface — check routing/cabling before flooding."
        return 1
    fi

    local destmac tries
    for tries in 1 2 3 4 5 6; do
        destmac=$(ip neigh show "$nexthop" dev "$iface" 2>/dev/null | awk '/lladdr/{for(i=1;i<=NF;i++) if($i=="lladdr") print $(i+1)}' | head -1)
        [ -n "$destmac" ] && break
        sleep 0.5
        _fd_udp_probe "$iface" "$destip" "$FLOOD_DPORT" "$FLOOD_SPORT" >/dev/null 2>&1
    done
    if [ -z "$destmac" ]; then
        echo "floodsd setup: probe(s) sent but no ARP entry resolved for $nexthop on $iface — check routing/cabling before flooding."
        _fd_diagnose_probe "$iface" "$destip" "$FLOOD_DPORT" "$FLOOD_SPORT" "$nexthop"
        return 1
    fi

    _floodsd_set if "$iface"
    _floodsd_set destip "$destip"
    _floodsd_set destmac "$destmac"
    echo "Target confirmed: $destip via $nexthop ($destmac) reachable via $iface."
}

# floodsd setup-srcport: override the UDP source port the probe, kernel
# pktgen, and DPDK pktgen all egress from (default: 8424). Needed when this
# box's egress firewall pins outbound traffic to a source port other than
# the default — that port is whatever the box's owner/network team
# allowlisted, so ask them, or find it by testing: `sudo tcpdump -ni <iface>
# udp` while sending traffic from candidate ports shows whether packets
# actually leave the NIC. Persisted like the rest of the target state, so it
# survives across setup/dpdk/kernel invocations; re-run `floodsd setup`
# afterward to re-probe with the new port.
_floodsd_setup_srcport() {
    local cur port
    cur=$(_floodsd_get sport); cur=${cur:-$FLOOD_SPORT}
    read -rp "UDP source port to egress from (Enter = keep '$cur'): " port
    port=${port:-$cur}
    if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        echo "floodsd setup-srcport: invalid port '$port'."
        return 1
    fi
    _floodsd_set sport "$port"
    FLOOD_SPORT=$port
    echo "Source port set to $port. Re-run 'floodsd setup' to re-probe with the new port."
}

# _fd_ensure_pktgen_module: modprobe the in-kernel pktgen module, installing
# it first if missing. Debian/Ubuntu ship it in "linux-modules-extra-$(uname
# -r)", sometimes absent on minimal cloud images. RHEL-family is messier and
# has moved the package across releases: older RHEL/Rocky/Alma 9 shipped it
# in "kernel-modules-extra", but newer RHEL-9-derivative point releases
# (e.g. current Rocky Linux 9) moved pktgen and other net testing/debugging
# modules into "kernel-modules-internal" instead — so both are tried,
# internal first since that's where it lives on current RHEL-family
# releases. Package name is matched to the running kernel version so it
# isn't left on a mismatched/newer kernel package after an update.
_fd_ensure_pktgen_module() {
    sudo modprobe pktgen 2>/dev/null && return 0

    echo "floodsd kernel: 'pktgen' kernel module not found — installing for kernel $(uname -r)..."
    local krel; krel=$(uname -r)
    if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update -y
        sudo apt-get install -y "linux-modules-extra-${krel}" \
            || { echo "floodsd kernel: couldn't install linux-modules-extra-${krel} — install it manually."; return 1; }
    elif command -v dnf >/dev/null 2>&1; then
        sudo dnf install -y "kernel-modules-internal-${krel}" 2>/dev/null \
            || sudo dnf install -y "kernel-modules-extra-${krel}" \
            || { echo "floodsd kernel: couldn't install kernel-modules-internal-${krel} or kernel-modules-extra-${krel} — install it manually."; return 1; }
    elif command -v yum >/dev/null 2>&1; then
        sudo yum install -y "kernel-modules-internal-${krel}" 2>/dev/null \
            || sudo yum install -y "kernel-modules-extra-${krel}" \
            || { echo "floodsd kernel: couldn't install kernel-modules-internal-${krel} or kernel-modules-extra-${krel} — install it manually."; return 1; }
    else
        echo "floodsd kernel: no supported package manager found (apt-get/dnf/yum) — install the pktgen kernel module manually."
        return 1
    fi

    sudo modprobe pktgen \
        || { echo "floodsd kernel: installed the package but 'modprobe pktgen' still fails — check 'uname -r' matches the installed module package."; return 1; }
}

# _fd_kernel_valid_rate <rate>: true if <rate> is "max" (any case) or a
# non-negative number.
_fd_kernel_valid_rate() {
    case "$1" in
        [Mm][Aa][Xx]) return 0 ;;
        *) [[ "$1" =~ ^[0-9]+([.][0-9]+)?$ ]] ;;
    esac
}

# _fd_kernel_norm_rate <rate>: canonicalizes "max"/"Max"/etc to "MAX".
_fd_kernel_norm_rate() {
    case "$1" in
        [Mm][Aa][Xx]) echo MAX ;;
        *) echo "$1" ;;
    esac
}

# _fd_kernel_set_delay <iface> <ncores> <rate>: computes the per-thread
# nanosecond delay for <rate> Mpps split evenly across <ncores> threads
# (MAX = 0 delay, i.e. no throttling) and writes it to each configured
# device. Safe to call on a running flood or a stopped one — pktgen doesn't
# document live reconfiguration of an active device, so callers that want a
# rate change to apply mid-flood are expected to stop/restart around this
# (see the 'start <rate>' command in _floodsd_kernel).
_fd_kernel_set_delay() {
    local iface=$1 ncores=$2 rate=$3
    local delay_ns i
    if [ "$rate" = MAX ]; then
        delay_ns=0
    else
        delay_ns=$(awk -v mpps="$rate" -v cores="$ncores" 'BEGIN {
            total_pps = mpps * 1000000;
            pps_per_core = total_pps / cores;
            printf "%d", 1000000000 / pps_per_core
        }')
    fi
    for ((i = 0; i < ncores; i++)); do
        echo "delay $delay_ns" | sudo tee "/proc/net/pktgen/${iface}@${i}" >/dev/null
    done
}

# _fd_kernel_pkt_total <iface> <ncores>: sums "pkts-sofar" across all
# configured devices — used to compute the live Mpps counter.
_fd_kernel_pkt_total() {
    local iface=$1 ncores=$2 i val total=0
    for ((i = 0; i < ncores; i++)); do
        # sudo'd: pktgen's proc entries are commonly root-read-only (0600), so
        # an unprivileged read here just silently fails (2>/dev/null hides
        # it), permanently pinning the Mpps counter at 0 on boxes like that.
        val=$(sudo grep "pkts-sofar" "/proc/net/pktgen/${iface}@${i}" 2>/dev/null | awk '{print $2}')
        total=$((total + val))
    done
    echo "$total"
}

# _fd_kernel_thread_has_devices <core>: true if kpktgend_<core> still lists
# a device on its "Running:" or "Stopped:" line (pktgen's proc format —
# both list attached devices regardless of send state).
_fd_kernel_thread_has_devices() {
    local f="/proc/net/pktgen/kpktgend_${1}"
    [ -e "$f" ] || return 1
    # sudo'd: these proc entries are commonly root-read-only (0600). Without
    # it, an unprivileged read fails outright ("awk: fatal: cannot open ...
    # Permission denied") instead of just returning false — and since this
    # runs once per core per cleanup attempt, that's the exact failure that
    # spams dozens of near-identical errors on a box with many cores.
    sudo awk -F': ' '/^Running:|^Stopped:/ { if (length($2) > 0) found=1 } END { exit !found }' "$f"
}

# _fd_kernel_cleanup_all: stop sending and rem_device_all across *every*
# kpktgend_N thread (0..nproc-1) — not just whatever core range the current
# session picked. This is the fix for a real bug: pgctrl start/stop is
# global to the whole pktgen subsystem, but device (re)configuration used to
# only touch the top-N cores requested *this* run. Shrinking the core count
# between 'floodsd kernel' sessions (or re-pointing at a new target via
# 'floodsd setup' in between) left lower-numbered cores' devices attached
# with their old dst/delay — and 'start' would fire them too, silently
# flooding a stale target alongside the intended one. Verifies the sweep
# actually took (retrying once) rather than assuming rem_device_all worked;
# returns 1 (with a warning already printed) if devices are still stuck.
_fd_kernel_cleanup_all() {
    echo "stop" | sudo tee /proc/net/pktgen/pgctrl >/dev/null 2>&1

    local hi=$(( $(nproc) - 1 )) n attempt leftover
    for attempt in 1 2; do
        for ((n = 0; n <= hi; n++)); do
            [ -e "/proc/net/pktgen/kpktgend_${n}" ] || continue
            echo "rem_device_all" | sudo tee "/proc/net/pktgen/kpktgend_${n}" >/dev/null 2>&1
        done
        leftover=0
        for ((n = 0; n <= hi; n++)); do
            _fd_kernel_thread_has_devices "$n" && leftover=$((leftover + 1))
        done
        [ "$leftover" -eq 0 ] && return 0
        [ "$attempt" -eq 1 ] && echo "floodsd kernel: $leftover thread(s) still show attached devices after cleanup — retrying..."
    done

    echo "floodsd kernel: WARNING — $leftover pktgen thread(s) still have devices attached after two cleanup attempts."
    echo "  Check manually: sudo grep -l 'Stopped: \\|Running: ' /proc/net/pktgen/kpktgend_* 2>/dev/null | xargs -r sudo grep -H 'Stopped:\\|Running:'"
    return 1
}

# _fd_kernel_write <file> <cmd>: writes one pktgen command, checking the
# result instead of firing-and-forgetting it. pktgen proc writes fail in
# more ways than you'd expect (permission issues, or kernel-internal error
# codes like ENOTSUPP=524 leaking through untranslated as "tee: ... Unknown
# error 524" — classically from queue_map_min/max exceeding what the
# NIC/bond actually supports) — and without a check, one bad write silently
# cascades through the rest of that device's commands, then repeats
# identically for every remaining core. Names the exact command and file
# that failed instead.
_fd_kernel_write() {
    local file=$1 cmd=$2
    if ! echo "$cmd" | sudo tee "$file" >/dev/null; then
        echo "floodsd kernel: '$cmd' -> $file failed." >&2
        return 1
    fi
}

# floodsd kernel: in-kernel pktgen flood, driven by an interactive prompt
# (loosely mirroring pktgen-dpdk's own interactive CLI). pktgen's kernel
# threads (kpktgend_N) are pinned 1:1 to CPU N, so "core selection" here just
# means which kpktgend_N thread a device gets loaded into — cores are picked
# top-down (highest first) to match pktfd's convention and avoid low cores
# other tools tend to pin to. Core count is fixed for the session (asked
# once, up front); quit and re-run to change it. Commands at the prompt:
#   start            start (or, if already running, no-op) at the current rate
#   start <mpps|max> set the rate and (re)start — if already running, this
#                    stops, rewrites the per-thread delay, and restarts
#                    (a brief sub-second gap; pktgen doesn't document live
#                    reconfiguration of an actively-sending device)
#   stop             halt sending; devices stay configured, 'start' resumes
#   quit / exit      full cleanup (stop + rem_device_all everywhere,
#                    verified — see _fd_kernel_cleanup_all), then leave
# Ctrl-C and EOF (Ctrl-D) both behave like 'quit' rather than leaving an
# orphaned flood with no controlling shell. There's deliberately no
# 'floodsd restore' equivalent for the kernel engine — quit's own cleanup
# is what's supposed to guarantee nothing is left running/attached.
_floodsd_kernel() {
    local iface destip destmac
    iface=$(_floodsd_get if); destip=$(_floodsd_get destip); destmac=$(_floodsd_get destmac)
    if [ -z "$iface" ] || [ -z "$destip" ] || [ -z "$destmac" ]; then
        echo "floodsd kernel: no target configured — run 'floodsd setup' first."
        return 1
    fi
    if ! ip link show "$iface" >/dev/null 2>&1; then
        echo "floodsd kernel: interface '$iface' not found (was it rebound to vfio-pci? check 'floodsd restore')."
        return 1
    fi

    if [ -d "/sys/class/net/$iface/bonding" ]; then
        local slaves; slaves=$(cat "/sys/class/net/$iface/bonding/slaves" 2>/dev/null)
        echo "floodsd kernel: '$iface' is a bonding master — kernel pktgen doesn't work reliably against it."
        echo "  pktgen injects packets directly into a real per-queue hardware TX ring; a bond is a purely"
        echo "  software netdevice with no such thing, and driving it this way tends to surface as skb/"
        echo "  protocol errors rather than a clean failure."
        echo "  Re-run 'floodsd setup' and pick one of its slaves${slaves:+ ($slaves)} instead."
        return 1
    fi

    local curcores ncores
    curcores=$(_floodsd_get kerncores); curcores=${curcores:-4}
    read -rp "TX cores/threads? [${curcores}] " ncores
    ncores=${ncores:-$curcores}
    if ! [[ "$ncores" =~ ^[0-9]+$ ]] || [ "$ncores" -lt 1 ]; then
        echo "floodsd kernel: invalid core count '$ncores'."
        return 1
    fi
    _floodsd_set kerncores "$ncores"

    local hi=$(( $(nproc) - 1 )) lo
    lo=$((hi - ncores + 1))
    if [ "$lo" -lt 0 ]; then
        echo "floodsd kernel: $ncores cores would run past core 0 (highest core = $hi). Choose fewer."
        return 1
    fi

    local rate; rate=$(_floodsd_get kernrate); rate=${rate:-MAX}

    _fd_ensure_pktgen_module || return 1
    # Clean slate across ALL threads, not just the ones this session picked —
    # otherwise a previous run with a larger core count (or a different
    # target) can leave stale devices attached that 'start' would fire too.
    _fd_kernel_cleanup_all

    local i core dev thread cmd
    for ((i = 0; i < ncores; i++)); do
        core=$((hi - i))
        thread="kpktgend_${core}"
        dev="${iface}@${i}"

        if ! _fd_kernel_write "/proc/net/pktgen/$thread" "add_device $dev"; then
            echo "  If this is 'Permission denied' despite running as root, it's very likely SELinux (common on hardened RHEL-family boxes):"
            echo "    getenforce                                 # check if it's Enforcing"
            echo "    sudo ausearch -m avc -ts recent | grep -i pktgen   # see the actual denial"
            echo "  A permissive test: 'sudo setenforce 0' (temporary, reverts on reboot) — or get a policy module allowing this from whoever owns the box."
            return 1
        fi

        for cmd in "count 0" "clone_skb 10000" "pkt_size 64" \
                   "queue_map_min $i" "queue_map_max $i" \
                   "dst $destip" "dst_mac $destmac" \
                   "udp_src_min $FLOOD_SPORT" "udp_src_max $FLOOD_SPORT" \
                   "udp_dst_min $FLOOD_DPORT" "udp_dst_max $FLOOD_DPORT"; do
            if ! _fd_kernel_write "/proc/net/pktgen/$dev" "$cmd"; then
                case "$cmd" in
                    queue_map_*)
                        echo "  '$cmd' failing often means $iface (or its bond) doesn't have that many TX queues."
                        echo "  Check: ethtool -l $iface   (or: ls /sys/class/net/$iface/queues/tx-* | wc -l)"
                        echo "  and try fewer TX cores/threads than it reports."
                        ;;
                esac
                return 1
            fi
        done
    done
    _fd_kernel_set_delay "$iface" "$ncores" "$rate"

    echo "Configured $ncores TX cores (cores $lo-$hi) -> $destip ($destmac) via $iface."
    echo "Commands: start | start <mpps|max> | stop | rate | quit"

    local running=0 p1=0 p2 diff mpps line rc last_t=0 now prompt_shown=0
    trap 'echo; _fd_kernel_cleanup_all && echo "Stopped — all pktgen devices cleared."; echo "Exiting."; trap - INT; return 0' INT

    # Polls every 10s (not `read -p`, which reprints its prompt on every
    # call — including every timeout tick — with no leading newline; that
    # piled up duplicate prompts on one physical line when idle, and while
    # running glued the periodic status onto whatever you were mid-typing).
    # Printing the prompt ourselves, only once until a submitted line or a
    # status update invalidates it, keeps each on its own line. A 1-second
    # tick made this collide with in-progress typing often enough to be
    # annoying; at 10s it's rare enough to live with in exchange for the
    # live ticker. 'rate' still gives you a check in between ticks.
    while true; do
        local prompt="floodsd kernel"
        [ "$running" = 1 ] && prompt="floodsd kernel [running, ${rate} Mpps]"

        if [ "$prompt_shown" = 0 ]; then
            printf '%s> ' "$prompt"
            prompt_shown=1
        fi

        if IFS= read -r -t 10 line; then
            prompt_shown=0
            case "$line" in
                start)
                    if [ "$running" = 1 ]; then
                        echo "Already running at ${rate} Mpps."
                    else
                        # This write blocks until 'stop' is written elsewhere (pktgen's own
                        # semantics), so it has to run in the background — but the script
                        # isn't under interactive job control, so a backgrounded job shares
                        # the foreground process group and Ctrl-C's SIGINT hits it directly.
                        # Some sudo builds handle a raw SIGINT mid-flight badly enough to trip
                        # glibc's fortify stack-protector ("longjmp causes uninitialized stack
                        # frame"). The INT trap below already shuts this down gracefully (by
                        # writing 'stop', which unblocks it cleanly) — ignoring INT here just
                        # stops the terminal's raw signal from also hitting it first.
                        ( trap '' INT; echo "start" | sudo tee /proc/net/pktgen/pgctrl >/dev/null ) &
                        running=1
                        p1=$(_fd_kernel_pkt_total "$iface" "$ncores")
                        last_t=$(date +%s.%N)
                        echo "Started at ${rate} Mpps."
                    fi
                    ;;
                start\ *)
                    local newrate; newrate=$(echo "${line#start }" | xargs)
                    if ! _fd_kernel_valid_rate "$newrate"; then
                        echo "Invalid rate '$newrate' — use a number or MAX."
                    else
                        rate=$(_fd_kernel_norm_rate "$newrate")
                        _floodsd_set kernrate "$rate"
                        if [ "$running" = 1 ]; then
                            echo "stop" | sudo tee /proc/net/pktgen/pgctrl >/dev/null 2>&1
                        fi
                        _fd_kernel_set_delay "$iface" "$ncores" "$rate"
                        # Backgrounded + INT-ignoring for the same reason as the 'start' case above.
                        ( trap '' INT; echo "start" | sudo tee /proc/net/pktgen/pgctrl >/dev/null ) &
                        running=1
                        p1=$(_fd_kernel_pkt_total "$iface" "$ncores")
                        last_t=$(date +%s.%N)
                        echo "Rate set to ${rate} Mpps."
                    fi
                    ;;
                stop)
                    if [ "$running" = 1 ]; then
                        echo "stop" | sudo tee /proc/net/pktgen/pgctrl >/dev/null 2>&1
                        running=0
                        echo "Stopped (devices stay configured — 'start' resumes)."
                    else
                        echo "Already stopped."
                    fi
                    ;;
                rate)
                    if [ "$running" = 1 ]; then
                        p2=$(_fd_kernel_pkt_total "$iface" "$ncores")
                        now=$(date +%s.%N)
                        diff=$((p2 - p1))
                        mpps=$(awk -v diff="$diff" -v t0="$last_t" -v t1="$now" 'BEGIN {
                            dt = t1 - t0; if (dt <= 0) dt = 1
                            printf "%.2f", (diff / 1000000) / dt
                        }')
                        echo "  ~$mpps Mpps (since last check)"
                        p1=$p2; last_t=$now
                    else
                        echo "Not running."
                    fi
                    ;;
                quit | exit)
                    _fd_kernel_cleanup_all && echo "Stopped — all pktgen devices cleared."
                    trap - INT
                    return 0
                    ;;
                "") ;;
                *)
                    echo "Unknown command '$line'. Use: start | start <mpps|max> | stop | rate | quit"
                    ;;
            esac
        else
            rc=$?
            if [ "$rc" -gt 128 ]; then
                if [ "$running" = 1 ]; then
                    p2=$(_fd_kernel_pkt_total "$iface" "$ncores")
                    now=$(date +%s.%N)
                    diff=$((p2 - p1))
                    mpps=$(awk -v diff="$diff" -v t0="$last_t" -v t1="$now" 'BEGIN {
                        dt = t1 - t0; if (dt <= 0) dt = 1
                        printf "%.2f", (diff / 1000000) / dt
                    }')
                    echo
                    echo "  [$mpps Mpps]"
                    p1=$p2; last_t=$now
                    prompt_shown=0
                fi
            else
                # EOF (Ctrl-D / stdin closed) — same as quit.
                _fd_kernel_cleanup_all && echo "Stopped — all pktgen devices cleared."
                trap - INT
                return 0
            fi
        fi
    done
}

# floodsd stop: halt the in-kernel pktgen flood from a separate shell —
# devices stay configured. Exists as a kill switch independent of the
# interactive prompt above: kernel pktgen state outlives the shell that
# configured it, so if that session dies (SSH drop, closed terminal) while
# a flood is running, this is how you stop it.
_floodsd_stop() {
    echo "stop" | sudo tee /proc/net/pktgen/pgctrl >/dev/null 2>&1
    echo "Kernel pktgen stopped."
}

# _floodsd_ensure_dpdk: install DPDK + build Pktgen-DPDK from source if it
# hasn't been built yet. DPDK's dev packages are in standard distro repos
# (no user-dir equivalent without rebuilding DPDK itself from source, so
# this is the one system-wide install floodsd makes) but Pktgen-DPDK itself
# normally isn't packaged, so it's built from source into ~/.local/src and
# installed into ~/.local (bin + lib) — never /usr/local, since this box
# usually isn't yours.
PKTGEN_SRC_DIR="$HOME/.local/src/pktgen-dpdk"
PKTGEN_PREFIX="$HOME/.local"
PKTGEN_BIN="$PKTGEN_PREFIX/bin/pktgen"
_floodsd_ensure_dpdk() {
    [ -x "$PKTGEN_BIN" ] && return 0

    echo "floodsd dpdk: '$PKTGEN_BIN' not found."
    echo "  This installs DPDK's dev packages via the system package manager (the"
    echo "  one system-wide step — no user-dir equivalent), then clones + builds"
    echo "  Pktgen-DPDK from source into $PKTGEN_SRC_DIR, installed to $PKTGEN_PREFIX."
    local ans
    read -rp "Proceed? [y/N] " ans
    case "$ans" in
        y|Y|yes|Yes) ;;
        *) echo "Aborted — install pktgen manually, or re-run to retry."; return 1 ;;
    esac

    local pkgmgr
    if command -v apt-get >/dev/null 2>&1; then
        pkgmgr=apt
    elif command -v dnf >/dev/null 2>&1; then
        pkgmgr=dnf
    elif command -v yum >/dev/null 2>&1; then
        pkgmgr=yum
    else
        echo "floodsd dpdk: no supported package manager found (apt-get/dnf/yum) — install DPDK + Pktgen-DPDK manually."
        return 1
    fi

    echo "Installing DPDK + build dependencies ($pkgmgr)..."
    case "$pkgmgr" in
        apt)
            sudo apt-get update -y
            sudo apt-get install -y dpdk dpdk-dev meson ninja-build pkg-config libnuma-dev git gcc make \
                || { echo "floodsd dpdk: package install failed — install DPDK manually and re-run."; return 1; }
            ;;
        dnf|yum)
            # Minimal RHEL-family images (Rocky/Alma/RHEL 9) often lack a C
            # toolchain entirely — gcc/make aren't pulled in by dpdk-devel.
            local dpdk_pkgs=(dpdk dpdk-devel meson ninja-build pkgconf-pkg-config numactl-devel git gcc make)
            if ! sudo "$pkgmgr" install -y "${dpdk_pkgs[@]}" 2>/dev/null; then
                # dpdk-devel is sometimes unresolvable on a minimal RHEL-family 9
                # install until EPEL + CRB (CodeReady Builder, formerly
                # PowerTools) are enabled. Try enabling both, then retry once
                # before giving up.
                echo "floodsd dpdk: initial install failed — trying with EPEL + CRB enabled (common on minimal RHEL-family images)..."
                sudo "$pkgmgr" install -y epel-release dnf-plugins-core 2>/dev/null
                sudo dnf config-manager --set-enabled crb 2>/dev/null \
                    || sudo dnf config-manager --set-enabled powertools 2>/dev/null
                sudo "$pkgmgr" install -y "${dpdk_pkgs[@]}" \
                    || { echo "floodsd dpdk: package install failed even with EPEL/CRB enabled — install DPDK manually and re-run."; return 1; }
            fi
            ;;
    esac

    mkdir -p "$(dirname "$PKTGEN_SRC_DIR")"
    if [ -d "$PKTGEN_SRC_DIR/.git" ]; then
        echo "Updating existing Pktgen-DPDK checkout..."
        git -C "$PKTGEN_SRC_DIR" pull || return 1
    else
        echo "Cloning Pktgen-DPDK..."
        git clone https://github.com/pktgen/Pktgen-DPDK.git "$PKTGEN_SRC_DIR" || return 1
    fi

    echo "Building Pktgen-DPDK (meson + ninja), installing to $PKTGEN_PREFIX..."
    (
        cd "$PKTGEN_SRC_DIR" || exit 1
        rm -rf build
        meson setup build --prefix="$PKTGEN_PREFIX" --libdir=lib || exit 1
        ninja -C build || exit 1
        ninja -C build install || exit 1
    ) || { echo "floodsd dpdk: build failed — see output above."; return 1; }

    if [ ! -x "$PKTGEN_BIN" ]; then
        echo "floodsd dpdk: build reported success but $PKTGEN_BIN wasn't produced."
        return 1
    fi
    echo "pktgen installed: $PKTGEN_BIN"
}

# floodsd dpdk: bind the flood NIC to vfio-pci (skipped for Mellanox) and
# launch DPDK pktgen aimed at the saved target. Same core-layout convention
# as pktfd: main lcore highest, then RX, then TX cores going down — DPDK's
# main lcore runs control/CLI (no traffic) and pktgen dedicates one core to
# RX; every other core is TX (generation), and TX throughput scales with
# their count. Leaves you at pktgen's interactive prompt — 'start 0' and
# rate-limiting ('set 0 rate <pct>') are yours to run by hand.
_floodsd_dpdk() {
    local iface destip destmac
    iface=$(_floodsd_get if); destip=$(_floodsd_get destip); destmac=$(_floodsd_get destmac)
    if [ -z "$iface" ] || [ -z "$destip" ] || [ -z "$destmac" ]; then
        echo "floodsd dpdk: no target configured — run 'floodsd setup' first."
        return 1
    fi

    local curcores ntx
    curcores=$(_floodsd_get dpdkcores); curcores=${curcores:-1}
    echo "DPDK uses 1 lcore for control + 1 for RX; each extra TX core adds ~30 Mpps (64B)."
    read -rp "How many TX (generation) cores? [${curcores}] " ntx
    ntx=${ntx:-$curcores}
    if ! [[ "$ntx" =~ ^[0-9]+$ ]] || [ "$ntx" -lt 1 ]; then
        echo "floodsd dpdk: invalid TX core count '$ntx'."
        return 1
    fi
    _floodsd_set dpdkcores "$ntx"

    local plan main rxcore txlo txrange lcores map est
    plan=$(_fd_lcore_plan "floodsd dpdk" "$ntx") || return 1
    read -r main rxcore txlo txrange lcores map est <<< "$plan"

    _floodsd_ensure_dpdk || return 1
    if [ ! -e "/sys/class/net/$iface" ]; then
        echo "floodsd dpdk: no netdev for '$iface' — already bound to vfio-pci from a previous run? Check 'floodsd restore'."
        return 1
    fi

    if [ -d "/sys/class/net/$iface/bonding" ]; then
        local slaves; slaves=$(cat "/sys/class/net/$iface/bonding/slaves" 2>/dev/null)
        echo "floodsd dpdk: '$iface' is a bonding master — it has no PCI device, so DPDK can't bind it directly."
        echo "  'floodsd kernel' can't target it either (a bond has no real hardware TX ring for pktgen to drive)."
        echo "  Re-run 'floodsd setup' and pick one of its slaves${slaves:+ ($slaves)} to flood a single raw link."
        return 1
    fi

    _fd_bond_detach "$iface"

    local pci nicnode curdrv ifip
    pci=$(basename "$(readlink -f /sys/class/net/$iface/device)")
    nicnode=$(cat /sys/class/net/$iface/device/numa_node 2>/dev/null)
    curdrv=$(basename "$(readlink -f /sys/class/net/$iface/device/driver)" 2>/dev/null)
    ifip=$(ip -4 -o addr show dev "$iface" | awk '{print $4}' | head -1)

    local mellanox=0
    _fd_is_mellanox "$iface" "$curdrv" && mellanox=1

    _fd_check_numa "floodsd dpdk" "$iface" "$nicnode" "$txlo" "$main"

    echo "DPDK pktgen core plan on $iface:"
    echo "  $main    main lcore (DPDK control/CLI — no traffic)"
    echo "  $rxcore    RX core"
    echo "  $txrange  TX core(s) x$ntx  ->  ~${est} Mpps max (rough 30 Mpps/core guide, capped by NIC line rate)"

    _fd_reserve_hugepages "$ntx"

    [ "$mellanox" != 1 ] && _fd_vfio_bind floodsd "$iface" "$pci" "$curdrv" "$FLOODSD_VFIO_STATE" "" "$ifip"

    local cmds="$FLOODSD_DPDK_CMDS"
    mkdir -p "$(dirname "$cmds")"
    cat > "$cmds" <<EOF
set 0 dst mac $destmac
set 0 dst ip $destip
set 0 proto udp
set 0 dport $FLOOD_DPORT
set 0 sport $FLOOD_SPORT
set 0 size 64
disable 0 vlan
set 0 src ip ${ifip:-0.0.0.0}
EOF

    echo "Launching pktgen on $iface ($pci) -> $destip ($destmac), lcores $lcores (main $main)..."
    echo "(pktgen drops you at its interactive prompt — run 'start 0' yourself when ready.)"
    # Absolute path (not just "pktgen"): sudo's secure_path typically strips
    # ~/.local/bin from PATH. LD_LIBRARY_PATH is passed explicitly through
    # env since libpktgen.so lives in ~/.local/lib, outside the system
    # linker cache (sudo would otherwise reset the environment).
    sudo env LD_LIBRARY_PATH="$PKTGEN_PREFIX/lib" "$PKTGEN_BIN" -l "$lcores" -n 4 -a "$pci" --main-lcore "$main" -- -m "$map" -f "$cmds"
}

# floodsd restore: undo whatever `floodsd dpdk` did to hand the NIC over —
# rebind vfio-pci NICs to their kernel driver (see _fd_vfio_restore), and/or
# re-add the NIC to its bond if _fd_bond_detach pulled it out of one
# (Mellanox NICs skip the vfio-pci step entirely, so for those this bond
# reattach is the only restore step there is).
_floodsd_restore() {
    local attempted=0 failed=0
    if [ -f "$FLOODSD_VFIO_STATE" ]; then
        attempted=1
        _fd_vfio_restore "floodsd restore" "$FLOODSD_VFIO_STATE" || failed=1
    fi
    if [ -f "$FLOODSD_BOND_STATE" ]; then
        attempted=1
        _fd_bond_reattach || failed=1
    fi
    if [ "$attempted" = 0 ]; then
        echo "floodsd restore: nothing to restore (no vfio-pci bind or bond detach recorded)."
        return 1
    fi
    [ "$failed" = 1 ] && return 1
    return 0
}

# floodsd diagnose: read-only health check for a saved (or in-progress)
# target — link state, IP config, resolved next hop + live neighbor entry,
# rp_filter, python3 presence, and a best-effort grep of local firewall
# rules for the configured source port. Entirely opt-in — nothing else in
# floodsd calls this, so it never adds noise unless you run it yourself.
_floodsd_diagnose() {
    local iface destip destmac sport
    iface=$(_floodsd_get if); destip=$(_floodsd_get destip); destmac=$(_floodsd_get destmac)
    sport=$(_floodsd_get sport); sport=${sport:-$FLOOD_SPORT}

    echo "== floodsd diagnose =="
    echo "Source port: $sport (dport $FLOOD_DPORT)"
    command -v python3 >/dev/null 2>&1 || echo "  WARNING: python3 not found — 'floodsd setup' probes need it."

    if [ -z "$iface" ]; then
        echo "No target configured yet — run 'floodsd setup' first for interface-specific checks."
        return 0
    fi

    echo
    echo "Interface: $iface"
    if ! ip link show "$iface" >/dev/null 2>&1; then
        echo "  NOT FOUND — was it rebound to vfio-pci, or pulled into/out of a bond? Check 'floodsd restore'."
        return 1
    fi
    local state; state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null)
    echo "  operstate: ${state:-unknown}$( [ "$state" != up ] && echo '  <-- not up' )"
    ip -4 -o addr show dev "$iface" | awk '{print "  addr: "$4}'
    local bondtag; bondtag=$(_fd_bond_tag "$iface")
    [ -n "$bondtag" ] && echo "  $bondtag"

    local rpall rpif rpeff
    rpall=$(cat /proc/sys/net/ipv4/conf/all/rp_filter 2>/dev/null)
    rpif=$(cat "/proc/sys/net/ipv4/conf/$iface/rp_filter" 2>/dev/null)
    # The kernel applies max(all, per-interface), not just the per-interface
    # value — e.g. all=1 with iface=0 is still strict mode.
    rpeff=$(( ${rpall:-0} > ${rpif:-0} ? ${rpall:-0} : ${rpif:-0} ))
    echo "  rp_filter: all=${rpall:-?} $iface=${rpif:-?}$( [ "$rpeff" = 1 ] && echo '  <-- effective mode is strict; asymmetric-routed replies may get dropped' )"

    if [ -n "$destip" ]; then
        echo
        echo "Target: $destip (saved MAC: ${destmac:-none})"
        local nexthop; nexthop=$(_fd_nexthop_ip "$iface" "$destip")
        if [ -z "$nexthop" ]; then
            echo "  no route to $destip out $iface"
        else
            [ "$nexthop" != "$destip" ] && echo "  routed via $nexthop (not on-link)" || echo "  on-link"
            local live; live=$(ip neigh show "$nexthop" dev "$iface" 2>/dev/null)
            echo "  neighbor entry: ${live:-none}"
        fi
    fi

    if command -v iptables >/dev/null 2>&1; then
        local hits; hits=$(sudo iptables -S OUTPUT 2>/dev/null | grep -c -- "$sport")
        [ "${hits:-0}" -gt 0 ] && echo "  NOTE: iptables OUTPUT has $hits rule(s) mentioning '$sport' (may be coincidental — verify it ACCEPTs this traffic)"
    fi
}

floodsd() {
    case "${1:-}" in
        setup)         shift; _floodsd_setup "$@";         return ;;
        setup-srcport) shift; _floodsd_setup_srcport "$@"; return ;;
        diagnose)      shift; _floodsd_diagnose "$@";      return ;;
        dpdk)          shift; _floodsd_dpdk "$@";          return ;;
        kernel)        shift; _floodsd_kernel "$@";        return ;;
        stop)          shift; _floodsd_stop "$@";          return ;;
        restore)       shift; _floodsd_restore "$@";       return ;;
        *)
            echo "Usage: floodsd setup | setup-srcport | diagnose | dpdk | kernel | stop | restore"
            return 1
            ;;
    esac
}

floodsd "$@"
exit $?
